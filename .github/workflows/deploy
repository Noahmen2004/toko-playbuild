name: Deploy to GitHub Pages

on:
  push:
    branches: ["main"]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout je code
        uses: actions/checkout@v4
      
      - name: Installeer Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 24
          
      - name: Installeer dependencies
        run: npm install
        
      - name: Bouw de website
        env:
          CI: false
        run: npm run build
        
      - name: Upload de gebouwde bestanden
        uses: actions/upload-pages-artifact@v3
        with:
          path: ./dist

  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    needs: build
    runs-on: ubuntu-latest
    steps:
      - name: Zet live op GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
